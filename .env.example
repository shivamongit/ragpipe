# ─── ragpipe configuration ─────────────────────────────────────────────────
# Copy this to .env and fill in any keys you have. Only set what you want to use.
# ragpipe will auto-detect available providers and pick the best one.

# OpenAI (GPT-5, GPT-5 Mini, etc.)
# OPENAI_API_KEY=sk-...

# Anthropic (Claude Opus, Sonnet, Haiku)
# ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini (gemini-2.5-pro, gemini-2.5-flash)
# GOOGLE_API_KEY=...

# Groq (ultra-fast Llama, Mixtral, Qwen)
# GROQ_API_KEY=gsk_...

# Cohere (Command R+, Command R)
# COHERE_API_KEY=...

# Mistral AI (Mistral Large, Codestral)
# MISTRAL_API_KEY=...

# ─── Server settings (optional) ────────────────────────────────────────────
# Protect the API with a key (sent as X-API-Key header)
# RAGPIPE_API_KEY=

# SQLite path for conversation history
# RAGPIPE_DB=ragpipe.db
